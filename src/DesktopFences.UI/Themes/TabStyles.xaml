<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════
         Flat Tab Style — bottom indicator line, no rounded corners
         ══════════════════════════════════════════════════════ -->
    <Style x:Key="FlatTabButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="10,0,10,0" />
        <Setter Property="Height" Value="26" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6,6,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <!-- Bottom indicator line (transparent in idle) -->
                            <Border x:Name="Indicator"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Background="Transparent"
                                    CornerRadius="1"
                                    Margin="4,0,4,-1" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Flat active: subtle tinted bg + accent bottom indicator (v2 原型). -->
    <Style x:Key="FlatTabButtonActiveStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource FlatTabButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{DynamicResource TitleBarActiveBrush}"
                            CornerRadius="6,6,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Border Height="2"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1"
                                    Margin="4,0,4,-1" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         Segmented Tab Style — pill 形 (圆角 14)，active 用 accent 渐变填色
         ══════════════════════════════════════════════════════ -->
    <Style x:Key="SegmentedTabButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="12,0,12,0" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Margin" Value="2,0,2,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SegmentedTabButtonActiveStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SegmentedTabButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                <GradientStop Color="{DynamicResource AccentStrongColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════
         Rounded Tab Style — 顶部圆角 10,10,0,0；active 加 accent 底线 + 浅 tint
         ══════════════════════════════════════════════════════ -->
    <Style x:Key="RoundedTabButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="10,0,10,0" />
        <Setter Property="Height" Value="26" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10,10,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RoundedTabButtonActiveStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource RoundedTabButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="#1FFFFFFF"
                            CornerRadius="10,10,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Border Height="2"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1"
                                    Margin="6,0,6,-1" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
