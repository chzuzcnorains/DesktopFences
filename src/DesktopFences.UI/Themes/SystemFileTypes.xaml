<!--
    DesktopFences.UI / Themes / SystemFileTypes.xaml

    Phase 12: Windows-classic page-with-fold + colored badge file icons.
    14 个 DrawingImage（48×48 viewBox），与 FileTypes.xaml 的 FileIcon* 平级,
    Key 命名 SysFileIcon{Pascal}: SysFileIconFolder/Doc/Xls/Ppt/Pdf/Img/Video/
    Code/Sql/Ps1/Txt/Md/Exe/Zip/Music/Link/Ttf。

    设计来源: 设计原型/src/system-icons.jsx (SVG 版本)。

    特殊形状(无字母叠加):
        Folder — 黄色文件夹
        Img    — 紫色相片含 mountain 缩略图
        Video  — 黑色 filmstrip + 播放三角
        Exe    — 灰色 monitor + 蓝箭头 + 底座

    其他都是 page+fold+colored badge,字母由 SystemFileTile DataTemplate 的
    TextBlock 叠加绑定到 FileItemViewModel.SystemBadgeText.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═════ 共享 brush ═════ -->
    <LinearGradientBrush x:Key="SysPageBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#E3E7EE" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SysPageStroke" Color="#9AA3B5"/>
    <SolidColorBrush x:Key="SysFoldFill" Color="#CDD3DF"/>
    <SolidColorBrush x:Key="SysTextLine" Color="#C8CDD8" Opacity="0.7"/>

    <!-- ═════ Folder (黄色,独立造型) ═════ -->
    <LinearGradientBrush x:Key="SysFolderOuter" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFD66B" Offset="0"/>
        <GradientStop Color="#E8A93A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SysFolderInner" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFE28A" Offset="0"/>
        <GradientStop Color="#F0BB52" Offset="1"/>
    </LinearGradientBrush>

    <DrawingImage x:Key="SysFileIconFolder">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <DrawingGroup.ClipGeometry><RectangleGeometry Rect="0,0,48,48"/></DrawingGroup.ClipGeometry>
                <GeometryDrawing Brush="{StaticResource SysFolderOuter}">
                    <GeometryDrawing.Pen><Pen Brush="#A47620" Thickness="0.6"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><PathGeometry Figures="M 4 12 L 4 38 Q 4 41 7 41 L 41 41 Q 44 41 44 38 L 44 17 Q 44 14 41 14 L 22 14 L 18 10 L 7 10 Q 4 10 4 13 Z"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <DrawingGroup Opacity="0.9">
                    <GeometryDrawing Brush="{StaticResource SysFolderInner}">
                        <GeometryDrawing.Geometry><PathGeometry Figures="M 6 18 L 42 18 L 42 38 Q 42 39.5 40.5 39.5 L 7.5 39.5 Q 6 39.5 6 38 Z"/></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

