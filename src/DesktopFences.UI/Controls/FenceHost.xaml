<Window x:Class="DesktopFences.UI.Controls.FenceHost"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DesktopFences.UI.Controls"
        Title="Fence"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="False"
        SizeToContent="Manual">
    <!-- Outer margin for drop shadow space - set to 0 to remove the "border" gap -->
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <!-- Tab strip row — Height=0 when single panel, 28 when tabbed -->
            <RowDefinition x:Name="TabRow" Height="0" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tab strip (only visible when 2+ panels are grouped) -->
        <Border x:Name="TabStripBorder"
                Grid.Row="0"
                Background="#CC1E1E2E"
                CornerRadius="8,8,0,0"
                BorderThickness="0"
                Margin="0,0,0,-1">
            <Grid>
                <ItemsControl x:Name="TabStrip" Margin="0,0,58,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Button x:Name="TabRollupToggleButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,30,0"
                        Style="{StaticResource DarkIconButtonStyle}"
                        ToolTip="折叠/展开"
                        Click="TabRollupToggleButton_Click">
                    <ContentControl x:Name="TabRollupIcon"
                                    Template="{StaticResource IconTemplate}"
                                    Tag="{StaticResource IconRollup}"
                                    Width="14" Height="14"
                                    RenderTransformOrigin="0.5,0.5">
                        <ContentControl.RenderTransform>
                            <RotateTransform Angle="0" />
                        </ContentControl.RenderTransform>
                    </ContentControl>
                </Button>
                <Button x:Name="TabMenuButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        Style="{StaticResource DarkIconButtonStyle}"
                        ToolTip="菜单"
                        Click="TabMenuButton_Click">
                    <ContentControl Template="{StaticResource IconTemplate}"
                                    Tag="{StaticResource IconSettings}"
                                    Width="14" Height="14" />
                </Button>
            </Grid>
        </Border>

        <!-- Active fence panel -->
        <controls:FencePanel x:Name="FenceContent" Grid.Row="1" />
    </Grid>
</Window>
