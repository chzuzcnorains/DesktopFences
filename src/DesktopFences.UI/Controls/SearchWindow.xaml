<Window x:Class="DesktopFences.UI.Controls.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="搜索 Fence"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Border Background="#EE1E1E2E"
            CornerRadius="10"
            BorderBrush="#55888888"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5" />
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search box -->
            <Border Background="#33FFFFFF" CornerRadius="6" Padding="8,6">
                <TextBox x:Name="SearchBox"
                         Background="Transparent"
                         Foreground="#EEEEEE"
                         FontSize="16"
                         BorderThickness="0"
                         CaretBrush="White"
                         TextChanged="SearchBox_TextChanged" />
            </Border>

            <!-- Results list -->
            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     Margin="0,8,0,0"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"
                     KeyDown="ResultsList_KeyDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,3">
                            <Image Source="{Binding Icon}" Width="20" Height="20"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="#EEEEEE" FontSize="13" />
                                <TextBlock Text="{Binding FenceName}"
                                           Foreground="#88AAAAAA" FontSize="10" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="4,2" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#446688CC" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#226688CC" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Border>
</Window>
