<UserControl x:Class="DesktopFences.UI.Controls.Settings.ShortcutsSettingsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="快捷键" Style="{StaticResource SwPaneTitleStyle}" />
            <TextBlock Text="DesktopFences 注册的全局热键与窗口快捷键。后续版本将开放重绑定。"
                       Style="{StaticResource SwPaneDescStyle}" />
        </StackPanel>

        <!-- 3 groups; rows are built in code-behind to avoid 30 lines of repetitive XAML -->
        <StackPanel x:Name="GroupsRoot" />
    </StackPanel>
</UserControl>
