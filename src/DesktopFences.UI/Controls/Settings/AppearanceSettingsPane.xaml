<UserControl x:Class="DesktopFences.UI.Controls.Settings.AppearanceSettingsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="clr-namespace:DesktopFences.UI.Controls.Settings">
    <UserControl.Resources>
        <!-- Accent color circular swatch -->
        <Style x:Key="AccentSwatchStyle" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.3" Color="Black" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="active">
                    <Setter Property="BorderBrush" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab-style chooser tile -->
        <Style x:Key="TabStyleTileStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#1A000000" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="#0FFFFFFF" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="64" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#26FFFFFF" />
                </Trigger>
                <Trigger Property="Tag" Value="active">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Background" Value="#1F4E78B8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ValueLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <Style x:Key="CardSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,2,0,12" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Pane header -->
        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="外观" Style="{StaticResource SwPaneTitleStyle}" />
            <TextBlock Text="主题色、Fence 背景、模糊与图标渲染。所有调整即时反映在右侧预览中，点击下方"
                       Style="{StaticResource SwPaneDescStyle}" />
            <TextBlock Text="保存 后写入 settings.json 并应用到所有 Fence。"
                       Style="{StaticResource SwPaneDescStyle}" />
        </StackPanel>

        <!-- Body: 2 columns. Left = control cards. Right = pinned preview. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- ── Left: control cards ────────────────────── -->
            <StackPanel Grid.Column="0">

                <!-- 主题色 -->
                <Border Style="{StaticResource SwCardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="主题色 · Accent"
                                   Style="{StaticResource SwSectionHeaderStyle}" />
                        <TextBlock Text="影响选中态、聚焦光晕、激活 Tab 与主按钮的颜色。"
                                   Style="{StaticResource CardSubtitleStyle}" />
                        <StackPanel x:Name="SwatchStrip"
                                    Orientation="Horizontal"
                                    Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- 背景色调 -->
                <Border Style="{StaticResource SwCardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="背景色调 · Hue"
                                       Style="{StaticResource SwSectionHeaderStyle}" />
                            <TextBlock x:Name="HueValueLabel"
                                       Text="h=220°"
                                       Style="{StaticResource ValueLabelStyle}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <TextBlock Text="将 Fence 背景在色相环上偏移；保持低饱和度，避免影响可读性。"
                                   Style="{StaticResource CardSubtitleStyle}" />
                        <Slider x:Name="HueSlider"
                                Style="{DynamicResource DarkSliderStyle}"
                                Minimum="0" Maximum="360"
                                TickFrequency="30"
                                ValueChanged="OnControlChanged" />
                    </StackPanel>
                </Border>

                <!-- Fence 透明度 -->
                <Border Style="{StaticResource SwCardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Fence 透明度 · Opacity"
                                       Style="{StaticResource SwSectionHeaderStyle}" />
                            <TextBlock x:Name="OpacityValueLabel"
                                       Text="85%"
                                       Style="{StaticResource ValueLabelStyle}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <TextBlock Text="降低数值得到更通透的玻璃感；过低会与桌面背景串色。"
                                   Style="{StaticResource CardSubtitleStyle}" />
                        <Slider x:Name="OpacitySlider"
                                Style="{DynamicResource DarkSliderStyle}"
                                Minimum="0.20" Maximum="0.90"
                                TickFrequency="0.05"
                                SmallChange="0.02" LargeChange="0.1"
                                ValueChanged="OnControlChanged" />
                    </StackPanel>
                </Border>

                <!-- 模糊强度 -->
                <Border Style="{StaticResource SwCardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="模糊强度 · Blur"
                                       Style="{StaticResource SwSectionHeaderStyle}" />
                            <TextBlock x:Name="BlurValueLabel"
                                       Text="26 px"
                                       Style="{StaticResource ValueLabelStyle}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <TextBlock Text="近似 CSS backdrop-filter，控制 Fence 阴影柔和度（WPF DropShadow 模拟）。"
                                   Style="{StaticResource CardSubtitleStyle}" />
                        <Slider x:Name="BlurSlider"
                                Style="{DynamicResource DarkSliderStyle}"
                                Minimum="0" Maximum="60"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnControlChanged" />
                    </StackPanel>
                </Border>

                <!-- 图标大小 -->
                <Border Style="{StaticResource SwCardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="图标大小 · Icon size"
                                       Style="{StaticResource SwSectionHeaderStyle}" />
                            <TextBlock x:Name="IconSizeValueLabel"
                                       Text="44 px"
                                       Style="{StaticResource ValueLabelStyle}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <TextBlock Text="Fence 内文件 tile 的图标本体尺寸；外框宽高自动随之缩放。"
                                   Style="{StaticResource CardSubtitleStyle}" />
                        <Slider x:Name="IconSizeSlider"
                                Style="{DynamicResource DarkSliderStyle}"
                                Minimum="28" Maximum="64"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnControlChanged" />
                    </StackPanel>
                </Border>

                <!-- 标签页样式 -->
                <Border Style="{StaticResource SwCardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="标签页样式 · Tab style"
                                   Style="{StaticResource SwSectionHeaderStyle}" />
                        <TextBlock Text="多 Fence 合并成 Tab 时的标签条外观；MenuOnly 隐藏标签条改用菜单切换。"
                                   Style="{StaticResource CardSubtitleStyle}" />
                        <UniformGrid x:Name="TabStyleGrid"
                                     Columns="2" Rows="2" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Right: live preview ────────────────────── -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                <settings:FencePreviewControl x:Name="Preview" />
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
