<UserControl x:Class="DesktopFences.UI.Controls.Settings.AdvancedSettingsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SwRowGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="16,12,16,12" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="高级" Style="{StaticResource SwPaneTitleStyle}" />
            <TextBlock Text="桌面嵌入参数、诊断日志与危险操作。部分项目改动后需要重启 DesktopFences 才能生效。"
                       Style="{StaticResource SwPaneDescStyle}" />
        </StackPanel>

        <!-- 桌面嵌入 -->
        <Border Style="{StaticResource SwCardStyle}" Padding="0" Margin="0,0,0,12">
            <StackPanel>
                <Border Padding="16,12"
                        BorderBrush="{DynamicResource SwRowDividerBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="桌面嵌入" Style="{StaticResource SwSectionHeaderStyle}" />
                </Border>

                <Grid Style="{StaticResource SwRowGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="兼容模式" Style="{StaticResource SwRowLabelStyle}" />
                        <TextBlock Text="禁用 z-order 管理（HWND_BOTTOM ↔ HWND_TOPMOST 切换），与其它桌面增强工具共存。"
                                   Style="{StaticResource SwRowDescStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkCompatibilityMode"
                              Grid.Column="1"
                              Style="{DynamicResource DarkCheckBoxStyle}"
                              VerticalAlignment="Center" />
                </Grid>

                <Border BorderBrush="{DynamicResource SwRowDividerBrush}" BorderThickness="0,1,0,0">
                    <Grid Style="{StaticResource SwRowGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="240" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Win+D 检测延迟" Style="{StaticResource SwRowLabelStyle}" />
                            <TextBlock Text="按下 Win+D 后等待多少毫秒再将 Fence 抬到 HWND_TOPMOST。默认 300 ms 与 Explorer 动画同步。"
                                       Style="{StaticResource SwRowDescStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderWinDDelay"
                                    Style="{DynamicResource DarkSliderStyle}"
                                    Minimum="0" Maximum="800"
                                    TickFrequency="50"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="SliderWinDDelay_ValueChanged" />
                            <TextBlock x:Name="WinDDelayValue"
                                       Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="300 ms" />
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- 诊断 -->
        <Border Style="{StaticResource SwCardStyle}" Padding="0" Margin="0,0,0,12">
            <StackPanel>
                <Border Padding="16,12"
                        BorderBrush="{DynamicResource SwRowDividerBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="诊断" Style="{StaticResource SwSectionHeaderStyle}" />
                </Border>

                <Grid Style="{StaticResource SwRowGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="启用调试日志" Style="{StaticResource SwRowLabelStyle}" />
                        <TextBlock Text="日志输出到 %APPDATA%\DesktopFences\log\，仅在排查问题时打开。"
                                   Style="{StaticResource SwRowDescStyle}" />
                    </StackPanel>
                    <CheckBox x:Name="ChkDebugLogging"
                              Grid.Column="1"
                              Style="{DynamicResource DarkCheckBoxStyle}"
                              VerticalAlignment="Center" />
                </Grid>

                <Border BorderBrush="{DynamicResource SwRowDividerBrush}" BorderThickness="0,1,0,0">
                    <Grid Style="{StaticResource SwRowGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="日志等级" Style="{StaticResource SwRowLabelStyle}" VerticalAlignment="Center" />
                        <ComboBox x:Name="CboLogLevel"
                                  Grid.Column="1"
                                  Style="{DynamicResource DarkComboBoxStyle}"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItemStyle}" />
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource SwRowDividerBrush}" BorderThickness="0,1,0,0">
                    <Grid Style="{StaticResource SwRowGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="打开日志文件夹" Style="{StaticResource SwRowLabelStyle}" />
                            <TextBlock Text="如果日志目录尚未创建，会自动创建后再打开。"
                                       Style="{StaticResource SwRowDescStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="打开"
                                Style="{DynamicResource DarkButtonStyle}"
                                Padding="14,6"
                                VerticalAlignment="Center"
                                Click="BtnOpenLogFolder_Click" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- 危险操作 -->
        <Border Style="{StaticResource SwCardStyle}" Padding="0">
            <StackPanel>
                <Border Padding="16,12"
                        BorderBrush="{DynamicResource SwRowDividerBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="危险操作" Style="{StaticResource SwSectionHeaderStyle}" />
                        <TextBlock Text="以下动作不可撤销，执行前会再次确认。"
                                   Style="{StaticResource SwSectionDescStyle}" />
                    </StackPanel>
                </Border>

                <Grid Style="{StaticResource SwRowGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="重置所有 Fence 布局" Style="{StaticResource SwRowLabelStyle}" />
                        <TextBlock Text="关闭全部 Fence、清空 layout.json，下次启动按默认 6 分类重建。"
                                   Style="{StaticResource SwRowDescStyle}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="重置"
                            Style="{DynamicResource DangerButtonStyle}"
                            Padding="14,6"
                            VerticalAlignment="Center"
                            Click="BtnResetLayout_Click" />
                </Grid>

                <Border BorderBrush="{DynamicResource SwRowDividerBrush}" BorderThickness="0,1,0,0">
                    <Grid Style="{StaticResource SwRowGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="清空分类规则" Style="{StaticResource SwRowLabelStyle}" />
                            <TextBlock Text="rules.json 清空，自动整理停止。Fence 内已分类的文件保留。"
                                       Style="{StaticResource SwRowDescStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="清空"
                                Style="{DynamicResource DangerButtonStyle}"
                                Padding="14,6"
                                VerticalAlignment="Center"
                                Click="BtnClearRules_Click" />
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource SwRowDividerBrush}" BorderThickness="0,1,0,0">
                    <Grid Style="{StaticResource SwRowGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="恢复所有默认设置" Style="{StaticResource SwRowLabelStyle}" />
                            <TextBlock Text="settings.json 还原为默认值（外观、行为、启动、高级），不影响 Fence 布局与规则。"
                                       Style="{StaticResource SwRowDescStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="恢复"
                                Style="{DynamicResource DangerButtonStyle}"
                                Padding="14,6"
                                VerticalAlignment="Center"
                                Click="BtnRestoreDefaults_Click" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
