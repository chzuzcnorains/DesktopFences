<UserControl x:Class="DesktopFences.UI.Controls.Settings.FencesManageSettingsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Pane header -->
        <Grid Margin="0,0,0,18">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Fence 管理" Style="{StaticResource SwPaneTitleStyle}" />
                <TextBlock Text="活动 Fence 一览；关闭的 Fence 会保留在最近关闭列表，可以一键恢复。"
                           Style="{StaticResource SwPaneDescStyle}" />
            </StackPanel>
            <Button x:Name="BtnNewFence"
                    Content="+ 新建 Fence"
                    Style="{DynamicResource AccentButtonStyle}"
                    Padding="12,6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="BtnNewFence_Click" />
        </Grid>

        <!-- Segmented: 活动 / 最近关闭 -->
        <Border Style="{StaticResource SwSegmentedContainerStyle}" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <ToggleButton x:Name="SegActive" Style="{StaticResource SwSegStyle}"
                              IsChecked="True"
                              Checked="SegActive_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="活动" VerticalAlignment="Center" />
                        <Border Style="{StaticResource SwSegCountStyle}">
                            <TextBlock x:Name="SegActiveCount" Text="0"
                                       FontSize="10.5"
                                       FontFamily="Consolas, monospace"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="SegClosed" Style="{StaticResource SwSegStyle}"
                              Checked="SegClosed_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="最近关闭" VerticalAlignment="Center" />
                        <Border Style="{StaticResource SwSegCountStyle}">
                            <TextBlock x:Name="SegClosedCount" Text="0"
                                       FontSize="10.5"
                                       FontFamily="Consolas, monospace"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- Active section -->
        <Grid x:Name="ActiveSection">
            <StackPanel>
                <Border Background="#0AFFFFFF"
                        BorderBrush="#0DFFFFFF"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel x:Name="ActiveListContainer">
                        <!-- Header -->
                        <Border Background="#26000000"
                                BorderBrush="#0AFFFFFF"
                                BorderThickness="0,0,0,1"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="名称"      Style="{StaticResource SwTableHeadCellStyle}" />
                                <TextBlock Grid.Column="1" Text="TAB 数"   Style="{StaticResource SwTableHeadCellStyle}" />
                                <TextBlock Grid.Column="2" Text="文件总数" Style="{StaticResource SwTableHeadCellStyle}" />
                                <TextBlock Grid.Column="3" Text="位置"     Style="{StaticResource SwTableHeadCellStyle}" />
                                <TextBlock Grid.Column="4" Text="尺寸"     Style="{StaticResource SwTableHeadCellStyle}" />
                            </Grid>
                        </Border>
                        <!-- Rows go here -->
                        <ItemsControl x:Name="ActiveRows" />
                        <!-- Empty state when no fences -->
                        <Border x:Name="ActiveEmpty"
                                Padding="20,30"
                                Visibility="Collapsed">
                            <TextBlock Text="还没有活动 Fence —— 用上方的 + 新建 Fence 按钮或桌面右键创建第一个。"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Footer toolbar -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="保存快照"
                            Style="{DynamicResource DarkButtonStyle}"
                            Padding="12,6" Margin="0,0,8,0"
                            Click="BtnSaveSnapshot_Click" />
                    <Button Content="导出布局…"
                            Style="{DynamicResource DarkButtonStyle}"
                            Padding="12,6" Margin="0,0,8,0"
                            Click="BtnExportLayout_Click" />
                    <Button Content="导入布局…"
                            Style="{DynamicResource DarkButtonStyle}"
                            Padding="12,6"
                            Click="BtnImportLayout_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Closed section -->
        <Grid x:Name="ClosedSection" Visibility="Collapsed">
            <StackPanel>
                <ItemsControl x:Name="ClosedGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Border x:Name="ClosedEmpty"
                        Style="{StaticResource SwEmptyContainerStyle}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🗑"
                                   FontSize="36"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="回收站为空"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="关闭 Fence 后会出现在这里，最多保留 20 条历史。"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
