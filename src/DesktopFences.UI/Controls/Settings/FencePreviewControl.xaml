<UserControl x:Class="DesktopFences.UI.Controls.Settings.FencePreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True">
    <!-- Stage = simulated wallpaper backdrop; v2 prototype .sw-preview-stage -->
    <Border CornerRadius="10"
            Padding="22"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3C5078" Offset="0" />
                <GradientStop Color="#293A5A" Offset="0.55" />
                <GradientStop Color="#3D4F73" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="实时预览"
                       Foreground="{DynamicResource TextFaintBrush}"
                       FontSize="10.5"
                       Margin="0,0,0,12"
                       HorizontalAlignment="Center" />

            <!-- Mini fence (mirrors real FencePanel chrome at smaller scale) -->
            <Border x:Name="MiniFence"
                    MinWidth="280"
                    MaxWidth="380"
                    CornerRadius="8"
                    BorderBrush="#1FFFFFFF"
                    BorderThickness="1"
                    SnapsToDevicePixels="True">
                <Border.Background>
                    <SolidColorBrush x:Name="FenceBgBrush" Color="#A91A2036" />
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect x:Name="FenceShadow"
                                      BlurRadius="26"
                                      ShadowDepth="6"
                                      Opacity="0.55"
                                      Color="Black" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border x:Name="TabStripContainer"
                            Grid.Row="0"
                            Padding="8,4"
                            Background="#26000000"
                            BorderBrush="#0DFFFFFF"
                            BorderThickness="0,0,0,1">
                        <StackPanel x:Name="TabStrip" Orientation="Horizontal" />
                    </Border>

                    <WrapPanel x:Name="TileWrap"
                               Grid.Row="1"
                               Margin="10,12,10,12"
                               HorizontalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
