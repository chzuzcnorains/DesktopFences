<UserControl x:Class="DesktopFences.UI.Controls.Settings.AboutSettingsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Hero block: large logo + name + version -->
        <Border Padding="0,4,0,20"
                BorderBrush="{DynamicResource SwRowDividerBrush}"
                BorderThickness="0,0,0,1"
                Margin="0,0,0,18">
            <StackPanel Orientation="Horizontal">
                <Border Width="72" Height="72"
                        CornerRadius="14"
                        Background="#0DFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="1">
                    <Image Source="{StaticResource AppLogoImage}" Width="48" Height="48" />
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="DesktopFences"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="VersionLine"
                               FontSize="12"
                               FontFamily="Consolas, 'Cascadia Mono', monospace"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"
                               Text="0.9.0 · Build 2026.04 · Windows x64" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Description -->
        <TextBlock TextWrapping="Wrap"
                   FontSize="13"
                   LineHeight="22"
                   MaxWidth="640"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,20"
                   Text="对标 Stardock Fences 的开源桌面整理工具。通过横向 Fence 分组、自动分类规则、Tab 合并和 Folder Portal 高效管理桌面文件；Win+D 后仍然可见，多显示器与桌面分页原生支持。" />

        <!-- 4-tile stats grid -->
        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,20">
            <Border Style="{StaticResource SwStatTileStyle}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock x:Name="StatActiveFences" Text="0" Style="{StaticResource SwStatNumberStyle}" />
                    <TextBlock Text="活动 Fence" Style="{StaticResource SwStatLabelStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SwStatTileStyle}" Margin="6,0">
                <StackPanel>
                    <TextBlock x:Name="StatManagedFiles" Text="0" Style="{StaticResource SwStatNumberStyle}" />
                    <TextBlock Text="已管理文件" Style="{StaticResource SwStatLabelStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SwStatTileStyle}" Margin="6,0">
                <StackPanel>
                    <TextBlock x:Name="StatRules" Text="0" Style="{StaticResource SwStatNumberStyle}" />
                    <TextBlock Text="分类规则" Style="{StaticResource SwStatLabelStyle}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SwStatTileStyle}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="StatUptime" Text="0 分" Style="{StaticResource SwStatNumberStyle}" />
                    <TextBlock Text="本次运行时长" Style="{StaticResource SwStatLabelStyle}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Links row -->
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="LinkChangelog" Text="更新日志" Margin="0,0,18,0"
                       FontSize="12.5" Cursor="Hand"
                       Foreground="{DynamicResource AccentBrush}"
                       MouseLeftButtonDown="LinkChangelog_Click" />
            <TextBlock x:Name="LinkCheckUpdate" Text="检查更新" Margin="0,0,18,0"
                       FontSize="12.5" Cursor="Hand"
                       Foreground="{DynamicResource AccentBrush}"
                       MouseLeftButtonDown="LinkCheckUpdate_Click" />
            <TextBlock x:Name="LinkConfigFolder" Text="打开配置目录" Margin="0,0,18,0"
                       FontSize="12.5" Cursor="Hand"
                       Foreground="{DynamicResource AccentBrush}"
                       MouseLeftButtonDown="LinkConfigFolder_Click" />
            <TextBlock x:Name="LinkLicense" Text="开源许可"
                       FontSize="12.5" Cursor="Hand"
                       Foreground="{DynamicResource AccentBrush}"
                       MouseLeftButtonDown="LinkLicense_Click" />
        </StackPanel>
    </StackPanel>
</UserControl>
