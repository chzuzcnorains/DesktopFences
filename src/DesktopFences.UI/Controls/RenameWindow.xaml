<Window x:Class="DesktopFences.UI.Controls.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名 Fence"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        Width="360" Height="180"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Border Background="#EE1E1E2E"
            CornerRadius="10"
            BorderBrush="#55888888"
            BorderThickness="1"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Original name -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="原名称："
                       Foreground="#AACCCCCC"
                       VerticalAlignment="Center"
                       FontSize="13" />
            <TextBlock x:Name="OriginalNameText"
                       Grid.Row="0" Grid.Column="1"
                       Foreground="#DDEEEEEE"
                       VerticalAlignment="Center"
                       FontSize="13"
                       TextTrimming="CharacterEllipsis" />

            <!-- New name -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="新名称："
                       Foreground="#AACCCCCC"
                       VerticalAlignment="Center"
                       FontSize="13" />
            <TextBox x:Name="NewNameBox"
                     Grid.Row="2" Grid.Column="1"
                     Background="#33FFFFFF"
                     Foreground="#DDEEEEEE"
                     CaretBrush="White"
                     BorderBrush="#55888888"
                     BorderThickness="1"
                     FontSize="13"
                     Padding="6,4"
                     VerticalContentAlignment="Center" />

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="确认" Width="70" Height="28"
                        FontSize="13"
                        Background="#446688CC"
                        Foreground="#DDEEEEEE"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="OkButton_Click" />
                <Button Content="取消" Width="70" Height="28"
                        FontSize="13"
                        Background="#33888888"
                        Foreground="#AACCCCCC"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="10,0,0,0"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
