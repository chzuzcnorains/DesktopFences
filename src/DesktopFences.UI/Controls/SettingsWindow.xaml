<Window x:Class="DesktopFences.UI.Controls.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:DesktopFences.UI.Controls.Settings"
        Title="桌面 Fence 设置"
        Width="960" Height="640"
        MinWidth="780" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#EE1A2036"
            CornerRadius="10"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="6" Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#10FFFFFF"
                    CornerRadius="10,10,0,0"
                    ClipToBounds="True"
                    BorderBrush="#0AFFFFFF"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource AppLogoImage}"
                               Width="14" Height="14"
                               Margin="16,0,8,0" />
                        <TextBlock Text="DesktopFences · 设置"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                ToolTip="最小化"
                                Click="BtnMinimize_Click">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconMin}"
                                            Width="14" Height="14" />
                        </Button>
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                ToolTip="最大化"
                                Click="BtnMaximize_Click">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconMax}"
                                            Width="12" Height="12" />
                        </Button>
                        <Button Style="{StaticResource CaptionCloseButtonStyle}"
                                ToolTip="关闭"
                                Click="BtnCancel_Click">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconClose}"
                                            Width="14" Height="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: sidebar + content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <ListBox x:Name="NavList" Grid.Column="0"
                         Style="{StaticResource SwNavListBoxStyle}"
                         ItemContainerStyle="{StaticResource SwNavItemStyle}"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Tag="general">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconSettings}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="常规" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="appearance">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconTheme}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="外观" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="rules">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconRule}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="分类规则" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="fences">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconGrid}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="Fence 管理" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="shortcuts">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconKeyboard}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="快捷键" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="advanced">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconLock}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="高级" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="about">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconInfo}"
                                            Width="16" Height="16" Margin="0,0,10,0" />
                            <TextBlock Text="关于" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Content -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="32,24,32,24">
                    <Grid>
                        <s:GeneralSettingsPane     x:Name="PaneGeneral"     Visibility="Visible" />
                        <s:AppearanceSettingsPane  x:Name="PaneAppearance"  Visibility="Collapsed" />
                        <s:RulesSettingsPane       x:Name="PaneRules"       Visibility="Collapsed" />
                        <s:FencesManageSettingsPane x:Name="PaneFences"     Visibility="Collapsed" />
                        <s:ShortcutsSettingsPane   x:Name="PaneShortcuts"   Visibility="Collapsed" />
                        <s:AdvancedSettingsPane    x:Name="PaneAdvanced"    Visibility="Collapsed" />
                        <s:AboutSettingsPane       x:Name="PaneAbout"       Visibility="Collapsed" />
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="#08FFFFFF"
                    BorderBrush="#0AFFFFFF" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,24,10">
                    <Button Content="保存" Width="80" Margin="0,0,8,0"
                            Click="BtnSave_Click"
                            Style="{DynamicResource AccentButtonStyle}" Padding="8,6" />
                    <Button Content="取消" Width="80"
                            Click="BtnCancel_Click"
                            Style="{DynamicResource DarkButtonStyle}" Padding="8,6" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
