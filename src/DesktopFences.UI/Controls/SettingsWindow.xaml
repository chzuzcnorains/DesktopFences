<Window x:Class="DesktopFences.UI.Controls.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面 Fence 设置"
        Width="680" Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1E1E2E">
    <Window.Resources>
        <!-- 美观的细滚动条样式 (4px) -->
        <Style x:Key="ThinScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Width="4">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#44FFFFFF" CornerRadius="2" Width="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollBar}"
                                       HorizontalAlignment="Right"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{TemplateBinding VerticalOffset}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#CCCCCC" />
                    <Setter Property="Background" Value="#33FFFFFF" />
                    <Setter Property="Padding" Value="16,6" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6,6,0,0"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,0,2,0">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#446688CC" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#44FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TabPanel IsItemsHost="True" Background="Transparent" />
                                    <Border Grid.Row="1" Background="#22FFFFFF"
                                            CornerRadius="0,6,6,6" Padding="12"
                                            BorderBrush="#33FFFFFF" BorderThickness="1"
                                            Margin="0,0,0,0">
                                        <ContentPresenter ContentSource="SelectedContent" />
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: 常规设置 -->
            <TabItem Header="常规设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4">
                    <StackPanel>
                        <!-- Appearance -->
                        <TextBlock Text="外观" FontSize="16" FontWeight="Bold"
                                   Foreground="#EEEEEE" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="默认 Fence 颜色" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="TxtFenceColor" Grid.Column="1"
                                     Background="#33FFFFFF" Foreground="White" BorderThickness="1"
                                     BorderBrush="#55888888" Padding="4" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="标题栏颜色" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="TxtTitleBarColor" Grid.Column="1"
                                     Background="#33FFFFFF" Foreground="White" BorderThickness="1"
                                     BorderBrush="#55888888" Padding="4" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="文字颜色" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="TxtTextColor" Grid.Column="1"
                                     Background="#33FFFFFF" Foreground="White" BorderThickness="1"
                                     BorderBrush="#55888888" Padding="4" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="默认透明度" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="SliderOpacity" Grid.Column="1"
                                    Minimum="0.1" Maximum="1.0" TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="标题字号" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="SliderFontSize" Grid.Column="1"
                                    Minimum="10" Maximum="20" TickFrequency="1"
                                    IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Behavior -->
                        <TextBlock Text="行为" FontSize="16" FontWeight="Bold"
                                   Foreground="#EEEEEE" Margin="0,16,0,10" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="吸附距离 (像素)" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="SliderSnapThreshold" Grid.Column="1"
                                    Minimum="0" Maximum="30" TickFrequency="5"
                                    IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                        </Grid>

                        <CheckBox x:Name="ChkQuickHide" Content="启用快速隐藏（双击桌面）"
                                  Foreground="#CCCCCC" Margin="0,0,0,8" />

                        <!-- Startup -->
                        <TextBlock Text="启动" FontSize="16" FontWeight="Bold"
                                   Foreground="#EEEEEE" Margin="0,16,0,10" />

                        <CheckBox x:Name="ChkStartWithWindows" Content="随 Windows 启动"
                                  Foreground="#CCCCCC" Margin="0,0,0,8" />

                        <CheckBox x:Name="ChkStartMinimized" Content="启动后最小化到托盘"
                                  Foreground="#CCCCCC" Margin="0,0,0,8" />

                        <!-- Advanced -->
                        <TextBlock Text="高级" FontSize="16" FontWeight="Bold"
                                   Foreground="#EEEEEE" Margin="0,16,0,10" />

                        <CheckBox x:Name="ChkCompatibilityMode" Content="兼容模式（禁用窗口层级管理）"
                                  Foreground="#CCCCCC" Margin="0,0,0,8" />

                        <CheckBox x:Name="ChkDebugLogging" Content="启用调试日志"
                                  Foreground="#CCCCCC" Margin="0,0,0,8" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: 分类规则 -->
            <TabItem Header="分类规则">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Rule List -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="规则列表" FontSize="13" FontWeight="Bold"
                                   Foreground="#EEEEEE" Margin="0,0,0,8" />

                        <ListBox x:Name="RulesListBox" Grid.Row="1"
                                 DisplayMemberPath="Name"
                                 Background="#22FFFFFF" Foreground="White"
                                 BorderBrush="#44FFFFFF" BorderThickness="1"
                                 SelectionChanged="RulesListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Padding" Value="6,4" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#446688CC" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FFFFFF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="添加" Width="60" Margin="0,0,8,0"
                                    Click="BtnAddRule_Click"
                                    Background="#446688CC" Foreground="White"
                                    BorderThickness="0" Padding="6,4" />
                            <Button Content="删除" Width="60"
                                    Click="BtnDeleteRule_Click"
                                    Background="#44AA4444" Foreground="White"
                                    BorderThickness="0" Padding="6,4" />
                        </StackPanel>
                    </Grid>

                    <!-- Right: Edit Form -->
                    <StackPanel Grid.Column="2" x:Name="EditPanel" IsEnabled="False">
                        <TextBlock Text="编辑规则" FontSize="13" FontWeight="Bold"
                                   Foreground="#EEEEEE" Margin="0,0,0,12" />

                        <!-- Name -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="规则名称" Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtRuleName" Grid.Column="1"
                                     Background="#33FFFFFF" Foreground="White"
                                     BorderBrush="#55888888" BorderThickness="1" Padding="4"
                                     TextChanged="TxtRuleName_TextChanged" />
                        </Grid>

                        <!-- Enabled -->
                        <CheckBox x:Name="ChkRuleEnabled" Content="启用此规则"
                                  Foreground="#CCCCCC" Margin="0,0,0,10"
                                  Checked="RuleFieldChanged" Unchecked="RuleFieldChanged" />

                        <!-- Priority -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="优先级" Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPriority" Grid.Column="1"
                                     Background="#33FFFFFF" Foreground="White"
                                     BorderBrush="#55888888" BorderThickness="1" Padding="4"
                                     TextChanged="RuleFieldChanged" />
                        </Grid>

                        <!-- Match Type -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="匹配方式" Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <ComboBox x:Name="CboMatchType" Grid.Column="1"
                                      SelectionChanged="CboMatchType_SelectionChanged" />
                        </Grid>

                        <!-- Pattern (hidden for IsDirectory) -->
                        <Grid Margin="0,0,0,8" x:Name="PatternRow">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="匹配模式" Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPattern" Grid.Column="1"
                                     Background="#33FFFFFF" Foreground="White"
                                     BorderBrush="#55888888" BorderThickness="1" Padding="4"
                                     TextChanged="RuleFieldChanged" />
                        </Grid>

                        <!-- Pattern hint -->
                        <TextBlock x:Name="TxtPatternHint" Grid.Column="1"
                                   Foreground="#88AAAAAA" FontSize="11"
                                   Margin="90,0,0,8" TextWrapping="Wrap" />

                        <!-- Target Fence -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="目标 Fence" Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <ComboBox x:Name="CboTargetFence" Grid.Column="1"
                                      SelectionChanged="RuleFieldChanged" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存" Width="80" Margin="0,0,8,0"
                    Click="BtnSave_Click" Background="#446688CC"
                    Foreground="White" BorderThickness="0" Padding="8,4" />
            <Button Content="取消" Width="80"
                    Click="BtnCancel_Click" Background="#44888888"
                    Foreground="White" BorderThickness="0" Padding="8,4" />
        </StackPanel>
    </Grid>
</Window>
