<UserControl x:Class="DesktopFences.UI.Controls.FencePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DesktopFences.UI.ViewModels"
             xmlns:ctrl="clr-namespace:DesktopFences.UI.Controls"
             x:Name="Root"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver"
             DragLeave="OnDragLeave"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ═════ Custom file tile: 彩色类型图标 + 字母叠加 ═════ -->
        <DataTemplate x:Key="CustomFileTile">
            <Border x:Name="ItemBorder"
                    Width="{DynamicResource FileTileWidth}"
                    Height="{DynamicResource FileTileHeight}"
                    Margin="2"
                    CornerRadius="4"
                    Background="Transparent"
                    MouseLeftButtonDown="FileItem_MouseLeftButtonDown"
                    MouseRightButtonUp="FileItem_MouseRightButtonUp"
                    MouseMove="FileItem_MouseMove"
                    ToolTip="{Binding FilePath}">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0"
                          Width="{DynamicResource FileTileIconSize}"
                          Height="{DynamicResource FileTileIconSize}"
                          HorizontalAlignment="Center">
                        <Image Source="{Binding Extension, Converter={StaticResource KindToIcon}}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding KindLabel}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   FontSize="{Binding KindLabel, Converter={StaticResource LabelLenToSize}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,5"
                                   IsHitTestVisible="False">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.45" Color="Black"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding DisplayName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="32"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="ItemBorder" Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ═════ Shell file tile: 走 ShellIconExtractor 的系统图标 ═════ -->
        <DataTemplate x:Key="ShellFileTile">
            <Border x:Name="ItemBorder"
                    Width="{DynamicResource FileTileWidth}"
                    Height="{DynamicResource FileTileHeight}"
                    Margin="2"
                    CornerRadius="4"
                    Background="Transparent"
                    MouseLeftButtonDown="FileItem_MouseLeftButtonDown"
                    MouseRightButtonUp="FileItem_MouseRightButtonUp"
                    MouseMove="FileItem_MouseMove"
                    ToolTip="{Binding FilePath}">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0"
                           Source="{Binding Icon, IsAsync=True}"
                           Width="{DynamicResource FileTileIconSize}"
                           Height="{DynamicResource FileTileIconSize}"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding DisplayName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="11"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="32"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="ItemBorder" Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Picks Custom vs Shell based on global UseCustomFileIcons resource. -->
        <ctrl:FileIconTemplateSelector x:Key="FileIconSelector"
                                       CustomTemplate="{StaticResource CustomFileTile}"
                                       ShellTemplate="{StaticResource ShellFileTile}"/>
        <Style x:Key="TitleBarVisibilityStyle" TargetType="{x:Type Border}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowTitleBar, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- When ShowTitleBar=False (tabs visible), remove top corners -->
        <Style x:Key="FenceBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowTitleBar, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                    <Setter Property="CornerRadius" Value="0,0,10,10"/>
                    <Setter Property="BorderThickness" Value="1,0,1,1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Outer glow border: accent / merge-target colored halo driven by VM flags.
             Rendered behind FenceBorder (same bounds) and carries the DropShadow.
             Invisible when no focus / drop / merge state is active. -->
        <Border x:Name="GlowBorder"
                Background="Transparent"
                BorderBrush="Transparent"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource FenceBorderStyle}">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMergeTarget}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6BD49A" BlurRadius="26" ShadowDepth="0" Opacity="0.55"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDropHover}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#7AA7E6" BlurRadius="20" ShadowDepth="0" Opacity="0.55"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFocused}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#7AA7E6" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- Main fence body -->
        <Border x:Name="FenceBorder"
                Background="{DynamicResource FenceBackgroundBrush}"
                BorderBrush="{DynamicResource FenceBorderBrush}"
                Opacity="{Binding FenceOpacity, FallbackValue=1.0}"
                Effect="{StaticResource FenceShadowEffect}">
            <Border.Style>
                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource FenceBorderStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFocused}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource FenceBorderStrongBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title Bar (drag handle + rename) -->
                <Border x:Name="TitleBarBorder" Grid.Row="0"
                        Style="{StaticResource TitleBarVisibilityStyle}"
                        Background="{DynamicResource TitleBarBrush}"
                        CornerRadius="6,6,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        ToolTip="{Binding PortalDisplayPath}"
                        ToolTipService.IsEnabled="{Binding IsPortalMode}">
                    <Grid>
                        <TextBlock x:Name="TitleText"
                                   Text="{Binding Title, FallbackValue='新建 Fence'}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,60,0" />
                        <Button x:Name="RollupToggleButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,30,0"
                                Style="{StaticResource DarkIconButtonStyle}"
                                ToolTip="折叠/展开"
                                Click="RollupToggleButton_Click">
                            <ContentControl x:Name="RollupIcon"
                                            Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconRollup}"
                                            Width="14" Height="14"
                                            RenderTransformOrigin="0.5,0.5">
                                <ContentControl.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </ContentControl.RenderTransform>
                            </ContentControl>
                        </Button>
                        <Button x:Name="TitleMenuButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0"
                                Style="{StaticResource DarkIconButtonStyle}"
                                ToolTip="菜单"
                                Click="TitleMenuButton_Click">
                            <ContentControl Template="{StaticResource IconTemplate}"
                                            Tag="{StaticResource IconSettings}"
                                            Width="14" Height="14" />
                        </Button>
                    </Grid>
                </Border>

                <!-- File icons area — ListBox with virtualization enabled.
                     ItemTemplateSelector switches between CustomFileTile (self-drawn
                     colored type tiles) and ShellFileTile (system icon) based on
                     AppSettings.UseCustomFileIcons (applied via Application-level
                     resource key UseCustomFileIcons). -->
                <ListBox x:Name="FileListBox"
                         Grid.Row="1"
                         ItemsSource="{Binding Files}"
                         ItemTemplateSelector="{StaticResource FileIconSelector}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         Margin="4,2,4,4">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Empty state hint -->
                <TextBlock Grid.Row="1"
                           Foreground="{DynamicResource SubtleBorderBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="拖放文件到此处" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPortalMode}" Value="True">
                                    <Setter Property="Text" Value="右键标题栏可更改映射文件夹" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Resize grips (8 directions) -->
        <Thumb x:Name="GripTop" Cursor="SizeNS" Opacity="0"
               VerticalAlignment="Top" Height="5" Margin="5,0"
               DragDelta="GripTop_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripBottom" Cursor="SizeNS" Opacity="0"
               VerticalAlignment="Bottom" Height="5" Margin="5,0"
               DragDelta="GripBottom_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripLeft" Cursor="SizeWE" Opacity="0"
               HorizontalAlignment="Left" Width="5" Margin="0,5"
               DragDelta="GripLeft_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripRight" Cursor="SizeWE" Opacity="0"
               HorizontalAlignment="Right" Width="5" Margin="0,5"
               DragDelta="GripRight_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripTopLeft" Cursor="SizeNWSE" Opacity="0"
               VerticalAlignment="Top" HorizontalAlignment="Left" Width="8" Height="8"
               DragDelta="GripTopLeft_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripTopRight" Cursor="SizeNESW" Opacity="0"
               VerticalAlignment="Top" HorizontalAlignment="Right" Width="8" Height="8"
               DragDelta="GripTopRight_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripBottomLeft" Cursor="SizeNESW" Opacity="0"
               VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="8" Height="8"
               DragDelta="GripBottomLeft_DragDelta" DragCompleted="Grip_DragCompleted" />
        <Thumb x:Name="GripBottomRight" Cursor="SizeNWSE" Opacity="0"
               VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="8" Height="8"
               DragDelta="GripBottomRight_DragDelta" DragCompleted="Grip_DragCompleted" />
    </Grid>
</UserControl>
